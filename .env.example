# Copy this file to `.env.local` and fill in your Supabase project credentials
# (Project Settings → API in the Supabase dashboard). Never commit real secrets.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GIPHY API key (developers.giphy.com → Create an App), used by the GIF picker
VITE_GIPHY_API_KEY=your-giphy-key

# Web Push VAPID public key (generate with `npx web-push generate-vapid-keys`).
# Public by design — safe to ship in the client bundle. The matching private
# key is NOT an env var here; it's a secret for the future sending Edge
# Function, kept out of the repo entirely.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Product branding — keep the name a config value, not a hardcoded string,
# so the working title can change without touching the code.
VITE_APP_NAME=Freeword
